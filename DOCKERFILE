FROM golang:1.23-bookworm AS builder

WORKDIR /src

COPY go.mod ./
COPY cmd ./cmd
COPY internal ./internal
COPY pkg ./pkg

RUN CGO_ENABLED=0 GOOS=linux go build -o /out/kang-agent ./cmd/kang-agent

FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates libvirt-clients \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /out/kang-agent /usr/local/bin/kang-agent

EXPOSE 8081

ENTRYPOINT ["/usr/local/bin/kang-agent"]
